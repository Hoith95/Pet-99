	end

	if inst:IsA("ParticleEmitter") then
		inst.Enabled = false
		inst.Rate = 0
		return
	end

	if inst:IsA("Beam") then
		inst.Enabled = false
		return
	end

	if inst:IsA("Trail") then
		inst.Enabled = false
		return
	end

	if inst:IsA("Texture")
	or inst:IsA("Decal") then
		inst.Transparency = 1
		return
	end

	local parent = inst.Parent

	if parent and (
		parent.Name == "Orbs"
		or parent.Name == "Lootbags"
		or parent.Name == "Breakables"
	) then

		task.defer(cleanInstance, inst)
		return
	end

	task.defer(cleanInstance, inst)

end)

