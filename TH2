if _G.VAR_HT2 then
    return
end
_G.VAR_HT2 = true

task.wait(38)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local PlayerSave = require(Client.Save)

local function getSave()
    return PlayerSave.Get()
end

local Remote = ReplicatedStorage.Network.Instancing_FireCustomFromClient

while true do
    local sd = getSave()
    local tap = sd.TapHeroes or {}
    local rebirth = tap.Rebirths or 0

    -- Đã đủ 10 Rebirth -> Kết thúc

    if rebirth >= 10 then
        --print("[TapHeroes] Reached Rebirth 10")
        break
    end

    -- Chờ tới Zone >= 100

    repeat
        task.wait(1)
        sd = getSave()
        tap = sd.TapHeroes or {}
        rebirth = tap.Rebirths or 0
        if rebirth >= 10 then
            return
        end

    until (tap.CurrentZone or 0) >= 100

    -- Tắt Auto

    Remote:FireServer(
        "TapHeroes",
        "ZN_Auto",
        false
    )

    Remote:FireServer(
        "TapHeroes",
        "ZN_AutoRebirth",
        false
    )

    task.wait(0.5)

    -- Warp 100

    Remote:FireServer(
        "TapHeroes",
        "ZN_Warp",
        100
    )

    --print("[TapHeroes] Warp Lv100 - Farm 20 minutes")

    -- Farm 20 phút

    task.wait(20 * 60)

    -- Bật Auto

    Remote:FireServer(
        "TapHeroes",
        "ZN_Auto",
        true
    )

    Remote:FireServer(
        "TapHeroes",
        "ZN_AutoRebirth",
        true
    )

    --print("[TapHeroes] Resume Auto")

    -- Chờ Rebirth tăng

    local targetRebirth = rebirth + 1

    repeat
        task.wait(1)

        sd = getSave()
        tap = sd.TapHeroes or {}
        rebirth = tap.Rebirths or 0

        -- Nếu đã đủ 10 thì kết thúc luôn
        if rebirth >= 10 then
            return
        end
    until rebirth >= targetRebirth
    --print("[TapHeroes] Rebirth ->", rebirth)
end
