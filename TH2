if _G.VAR_HT2 then return end
_G.VAR_HT2 = true

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local PlayerSave = require(Client.Save)

local function getSave()
    return PlayerSave.Get()
end

while true do
    local sd = getSave()
    local beaten = sd.TapHeroesLevelsBeaten2026 or 0
    if beaten >= 238 then
        --warn("[TapHeroes] Reached 238 -> Disable Auto & Warp 100")
        ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(
            "TapHeroes",
            "ZN_Auto",
            false
        )

        ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(
            "TapHeroes",
            "ZN_AutoRebirth",
            false
        )

        task.wait(0.5)
        ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(
            "TapHeroes",
            "ZN_Warp",
            100
        )
        --warn("[TapHeroes] Farming Lv100 for 30 minutes...")
        task.wait(30 * 60)
        ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(
            "TapHeroes",
            "ZN_Warp",
            120
        )
        --warn("[TapHeroes] Warp to Lv120")
        break
    end
    task.wait(1)
end
