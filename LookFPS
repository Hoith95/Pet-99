if _G.LOOKFPS then
	warn("⛔ Script đã được chạy trước đó!")
	return
end
_G.LOOKFPS = true

-- ⚙️ CONFIG
local DEBUG = false

local FPS = {
	TIME_TRIAL = 7,

	LUCKY_EXCEPTION = 3,

	XMAS = {
		EARLY = 5,
		MID = 4,
		LATE = 3
	},

	DEFAULT_EARLY = 3,
	DEFAULT_LATE = 3
}

-- ⏱️ CONSTANT
local THREE_HOURS = 1689

-- 🚀 INIT
task.wait(138)
local startTime = tick()

task.spawn(function()
	local set = setfpscap or setfpscap
	local place = game.PlaceId
	local things = workspace:WaitForChild("__THINGS")
	local container = things:WaitForChild("__INSTANCE_CONTAINER")
	local currentFPS = nil

	-- 🔧 UTIL
	local function log(...)
		if DEBUG then
			print("[FPS]", ...)
		end
	end

	local function setFPS(v, reason)
		if currentFPS ~= v then
			currentFPS = v
			set(v)
			log("Set FPS:", v, "| Reason:", reason)
		end
	end

	local function getActive()
		return container:FindFirstChild("Active")
	end

	-- 🌍 STATE DETECT
	local function isTimeTrial(active)
		return active and active:FindFirstChild("TimeTrial")
	end

	local function isXmas(active)
		return active and active:FindFirstChild("XmasWorld")
	end

	local function isLucky(active)
		return active and (
			active:FindFirstChild("LuckyEventWorld")
			or active:FindFirstChild("LuckyRaid")
			or active:FindFirstChild("LuckyEgg")
		)
	end

	local function isLuckyException()
		return _G.P1 or _G.P2 or _G.P3 or _G.P4 or _G.P5
		or _G.SUU1 or _G.SUU2 or _G.SUU3 or _G.SUU4 or _G.SUU5
		or _G.G2 or _G.G3 or _G.G4 or _G.G8 or _G.G9 or _G.G10 or _G.G11
	end

	local function isLowFPSPlace(placeId)
		return placeId == 95635359880599
			or placeId == 119454325063278
			or placeId == 8737899170
			or placeId == 16498369169
			or placeId == 17503543197
			or placeId == 15502339080
	end

	-- 🧠 DEFAULT RULE
	local function getDefaultFPS(elapsed)
		if elapsed >= THREE_HOURS then
			return FPS.DEFAULT_LATE, "Default(After3h)"
		else
			return FPS.DEFAULT_EARLY, "Default(Early)"
		end
	end

	-- 🧠 CORE LOGIC
	local function resolveFPS()
		local active = getActive()
		local elapsed = tick() - startTime

		-- 🥇 Priority 1: Time Trial
		if isTimeTrial(active) then
			return FPS.TIME_TRIAL, "TimeTrial"
		end

		-- 🥈 Priority 2: Low FPS Place
		if isLowFPSPlace(place) then
			return FPS.DEFAULT_EARLY, "LowFPSPlace"
		end

		-- 🥉 Priority 3: Lucky Event
		if isLucky(active) then
			if isLuckyException() then
				if elapsed >= THREE_HOURS then
					return FPS.DEFAULT_LATE, "LuckyException(After3h)"
				else
					return FPS.LUCKY_EXCEPTION, "LuckyException(Early)"
				end
			else
				if elapsed >= THREE_HOURS then
					return FPS.DEFAULT_LATE, "LuckyNormal(After3h)"
				else
					return FPS.DEFAULT_EARLY, "LuckyNormal(Early)"
				end
			end
		end

		-- 🎄 Priority 4: Xmas
		if isXmas(active) then
			if elapsed >= 14400 then
				return FPS.XMAS.LATE, "XmasLate"
			elseif elapsed >= 7200 then
				return FPS.XMAS.MID, "XmasMid"
			else
				return FPS.XMAS.EARLY, "XmasEarly"
			end
		end

		-- 🧠 Default
		return getDefaultFPS(elapsed)
	end

	-- 🔁 OPTIMIZED LOOP
	while true do
		local active = getActive()

		local isActiveEvent = active and (
			active:FindFirstChild("TimeTrial")
			or active:FindFirstChild("LuckyEventWorld")
			or active:FindFirstChild("LuckyRaid")
			or active:FindFirstChild("LuckyEgg")
			or active:FindFirstChild("XmasWorld")
		)

		local waitTime = isActiveEvent and 0.01 or 0.1

		local fps, reason = resolveFPS()
		setFPS(fps, reason)

		task.wait(waitTime)
	end
end)
