if _G.LOOKFPS then
	warn("⛔ Script đã được chạy trước đó!")
	return
end
_G.LOOKFPS = true

-- ⚙️ AUTO FPS CONTROL ---

task.wait(68)
task.spawn(function()
	local set = setfpscap or setfpscap
	local place = game.PlaceId
	local t = workspace:WaitForChild("__THINGS")
	local container = t:WaitForChild("__INSTANCE_CONTAINER")
	local startTime = os.clock()
	local currentFPS = nil

	local function setFPS(v)
		if currentFPS ~= v then
			currentFPS = v
			set(v)
		end
	end

	local function getActive()
		return container:FindFirstChild("Active")
	end

	local function inXmasWorld()
		local active = getActive()
		return active and active:FindFirstChild("XmasWorld")
	end

	local function inLuckyEvent()
		local active = getActive()
		return active and (
			active:FindFirstChild("LuckyEventWorld")
			or active:FindFirstChild("LuckyRaid")
			or active:FindFirstChild("LuckyEgg")
		)
	end

	local function luckyException()
		return _G.P1
		or _G.P2
		or _G.P3
		or _G.P4
		or _G.P5
		or _G.SUU1
		or _G.SUU2
		or _G.SUU3
		or _G.SUU4
		or _G.SUU5
		or _G.G2
		or _G.G3
		or _G.G4
		or _G.G9
		or _G.G10
		or _G.G11
	end

	while task.wait(0.25) do
		local active = container:FindFirstChild("Active")
		local tt = active and active:FindFirstChild("TimeTrial")
		if place == 140403681187145 then
			if tt then
				setFPS(7)
			elseif inLuckyEvent() then
				if luckyException() then
					setFPS(4)
				else
					setFPS(6)
				end
			elseif inXmasWorld() then
				setFPS(4)
			else
				setFPS(3)
			end
		elseif place == 95635359880599
		or place == 119454325063278
		or place == 8737899170
		or place == 16498369169
		or place == 17503543197
		or place == 15502339080 then
			setFPS(3)
		elseif inLuckyEvent() then
			if luckyException() then
				setFPS(4)
			else
				setFPS(6)
			end
		elseif inXmasWorld() then
			local elapsed = os.clock() - startTime
			if elapsed >= 21600 then
				setFPS(4)
			elseif elapsed >= 14400 then
				setFPS(4)
			elseif elapsed >= 7200 then
				setFPS(4)
			else
				setFPS(4)
			end
		end
	end
end)
