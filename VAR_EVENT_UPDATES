if _G.VAR_EVENT_UPDATES then
    warn("⛔ Script đã chạy trước đó!")
    return
end
_G.VAR_EVENT_UPDATES = true

-- SERVICES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local PlayerSave = require(ReplicatedStorage.Library.Client.Save)
local Remote = ReplicatedStorage.Network:FindFirstChild("EventUpgrades: Purchase")

if not Remote then
    warn("❌ Không tìm thấy Remote EventUpgrades: Purchase")
    return
end

-- CONFIG
local PRIORITY = {
    {name = "LuckyRaidBetterLoot", max = 15},
    {name = "LuckyRaidDamage", max = 25},
    {name = "LuckyRaidPets", max = 31},
}

local ROUND_ROBIN = {
    {name = "LuckyRaidXP", max = 10},
    {name = "LuckyRaidAttackSpeed", max = 15},
    {name = "LuckyRaidPetSpeed", max = 15},
    {name = "LuckyRaidTitanicChest", max = 15},
    {name = "LuckyRaidBossTitanicChances", max = 10},
}

-- UTILS
local function getLevel(name)
    local save = PlayerSave.Get()
    if not save or not save.EventUpgrades then
        return 0
    end
    return save.EventUpgrades[name] or 0
end

local function isMax(up)
    return getLevel(up.name) >= up.max
end

local function tryUpgrade(name)
    for attempt = 1, 3 do
        local before = getLevel(name)

        Remote:InvokeServer(name)
        print("⬆️", name, "| Lần:", attempt, "| Level:", before)

        task.wait(3)

        local after = getLevel(name)
        if after > before then
            print("✅ Thành công:", name, "→", after)
            return true
        end
    end

    warn("⏭️ Bỏ qua (fail 3 lần):", name)
    return false
end

local function allMax()
    for _, up in ipairs(PRIORITY) do
        if not isMax(up) then return false end
    end
    for _, up in ipairs(ROUND_ROBIN) do
        if not isMax(up) then return false end
    end
    return true
end

-- MAIN LOOP
while true do
    if allMax() then
        print("🎯 Tất cả upgrade đã đạt max → dừng script")
        break
    end

    local anySuccess = false

    -- PHASE 1 → 3 (PRIORITY)
    for _, up in ipairs(PRIORITY) do
        while not isMax(up) do
            local success = tryUpgrade(up.name)

            if success then
                anySuccess = true
            else
                break -- fail 3 lần → dừng upgrade này
            end
        end

        -- nếu chưa max → không được sang upgrade tiếp theo
        if not isMax(up) then
            break
        end
    end

    -- PHASE 4 (ROUND ROBIN)
    if isMax(PRIORITY[1]) and isMax(PRIORITY[2]) and isMax(PRIORITY[3]) then
        for _, up in ipairs(ROUND_ROBIN) do
            if not isMax(up) then
                local success = tryUpgrade(up.name)
                if success then
                    anySuccess = true
                end
            end
        end
    end

    -- WAIT IF NO PROGRESS
    if not anySuccess then
        warn("😴 Không upgrade được gì → chờ 1 giờ rồi thử lại")
        task.wait(60 * 60)
    end
end
