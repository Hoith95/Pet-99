-- MARBLE COINS MONITOR

task.spawn(function()
    repeat
        task.wait(5)
    until HatchReady

    local lastCoins = getCurrencyAmount("MarbleCoins")
    local lastChange = tick()

    while true do

        task.wait(1)

        local coins = getCurrencyAmount("MarbleCoins")

        if coins ~= lastCoins then

            --print(string.format("[TapHeroes] MarbleCoins %s -> %s",lastCoins,coins))

            lastCoins = coins
            lastChange = tick()

        elseif tick() - lastChange >= 68 then

            local sd = getSave()

            local beaten = sd.TapHeroesLevelsBeaten2026 or 0
            local currentLevel = beaten + 1
            local targetLevel = math.max(currentLevel - 5, 1)

            --warn(string.format("[TapHeroes] No MarbleCoins 60s | Warp %d -> %d",currentLevel,targetLevel))

            ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(
                "TapHeroes",
                "ZN_Warp",
                targetLevel
            )

            lastCoins = getCurrencyAmount("MarbleCoins")
            lastChange = tick()

            task.wait(3)

        end

    end

end)

-- AUTO HATCH

--========================================================
-- AUTO HATCH
--========================================================

task.spawn(function()

    repeat
        task.wait(5)
    until HatchReady

    local customEggs = workspace.__THINGS:WaitForChild("CustomEggs")
    local hatchRemote = ReplicatedStorage.Network:WaitForChild("CustomEggs_Hatch")

    local currentEggName
    local currentEggModel

    local TELEPORT_DISTANCE = 40
    local EGG_OFFSET = 30 -- đứng trước egg 4 studs

    local function teleportToEgg(part)
        local targetPos = part.Position - part.CFrame.LookVector * EGG_OFFSET
        getRoot().CFrame = CFrame.lookAt(targetPos, part.Position)
        _G.LastTeleport = tick()
    end

    local function updateEgg()

        local foundName
        local foundModel

        for _, egg in ipairs(customEggs:GetChildren()) do
            if not egg.Name:find(" ") and #egg.Name >= 15 then
                foundName = egg.Name
                foundModel = egg
                break
            end
        end

        if foundName ~= currentEggName then

            currentEggName = foundName
            currentEggModel = foundModel

            if currentEggName then

                --print("[TapHeroes] New Egg:", currentEggName)

                local part =
                    currentEggModel.PrimaryPart
                    or currentEggModel:FindFirstChildWhichIsA("BasePart", true)

                if part then
                    teleportToEgg(part)
                    task.wait(0.3)
                end

            else
                --warn("[TapHeroes] Encoded Egg Not Found")
            end
        end
    end

    updateEgg()

    customEggs.ChildAdded:Connect(function()
        task.wait(0.1)
        updateEgg()
    end)

    customEggs.ChildRemoved:Connect(function()
        task.wait(0.1)
        updateEgg()
    end)

    while true do

        if currentEggName
        and currentEggModel
        and currentEggModel.Parent then

            local part =
                currentEggModel.PrimaryPart
                or currentEggModel:FindFirstChildWhichIsA("BasePart", true)

            if part then

                local delta = getRoot().Position - part.Position

                if delta:Dot(delta) > (TELEPORT_DISTANCE * TELEPORT_DISTANCE) then
                    print("[TapHeroes] Too Far -> Teleport Egg")
                    teleportToEgg(part)
                    task.wait(0.3)
                end

            end

            local args = {
                [1] = currentEggName,
                [2] = 89
            }

            local ok, result = pcall(function()
                return hatchRemote:InvokeServer(unpack(args))
            end)

            if ok then
                if result ~= nil then
                    --print("[TapHeroes] Hatch:", result)
                end
            else
                --warn("[TapHeroes] Hatch Error:", result)
            end

        else

            currentEggName = nil
            currentEggModel = nil

            updateEgg()

        end

        task.wait(0.1)

    end

end)

